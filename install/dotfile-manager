#!/bin/bash
# Dotfiles Manager - Install/Uninstall dotfiles using stow
# Usage: dotfiles-manager <install|uninstall>

set -e

# Colors for output
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
NC='\033[0m' # No Color

# Get script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
DOTFILES_PACKAGE="dotfiles"
DOTFILES_SRC="$PROJECT_ROOT/$DOTFILES_PACKAGE"
STOW_DIR="$PROJECT_ROOT"
LEGACY_DOTFILES_TARGET="$HOME/.dotfiles"

# Print functions
print_step() {
    echo -e "\n${BLUE}==>${NC} ${YELLOW}$1${NC}"
}

print_substep() {
    echo -e "  ${PURPLE}->${NC} $1"
}

print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[OK]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

is_valid_git_repo() {
    git -C "$PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

cleanup_stale_home_git_link() {
    local home_git="$HOME/.git"
    local resolved_target

    if [ -L "$home_git" ]; then
        resolved_target=$(readlink -f "$home_git" 2>/dev/null || true)
        if [ "$resolved_target" = "$LEGACY_DOTFILES_TARGET/.git" ]; then
            print_warning "Removing stale ~/.git symlink left by an earlier stow run"
            rm -f "$home_git"
        fi
    fi
}

cleanup_legacy_dotfiles_links() {
    if [ ! -d "$LEGACY_DOTFILES_TARGET" ]; then
        return 0
    fi

    print_substep "Cleaning up links from legacy ~/.dotfiles deployment"
    stow -D -d "$LEGACY_DOTFILES_TARGET" -t "$HOME" . 2>/dev/null || true
}

# Check required tools
check_tools() {
    for tool in stow git; do
        if ! command -v "$tool" &> /dev/null; then
            print_error "$tool is not installed. Please install it."
            exit 1
        fi
    done
}

# Install function
install_dotfiles() {
    print_step "Installing dotfiles using stow"

    # Check required tools
    check_tools

    if [ ! -d "$DOTFILES_SRC" ]; then
        print_error "Source directory not found: $DOTFILES_SRC"
        exit 1
    fi

    # Repository root must already be a valid Git repo because it is the source of truth.
    if ! is_valid_git_repo; then
        print_error "Project root is not a valid Git repository: $PROJECT_ROOT"
        exit 1
    fi

    print_substep "Configuring Git (ignore file mode changes)"
    git -C "$PROJECT_ROOT" config --local core.filemode false
    print_success "Git configured"

    # Clean up stale ~/.git symlink if a previous run incorrectly stowed .git.
    cleanup_stale_home_git_link
    cleanup_legacy_dotfiles_links

    # Unstow first (cleanup previous links)
    print_substep "Cleaning up previous stow links"
    stow -D -d "$STOW_DIR" -t "$HOME" "$DOTFILES_PACKAGE" 2>/dev/null || true
    print_success "Previous links cleaned"

    # Check for conflicts
    print_substep "Checking for conflicts"
    if ! stow -n -d "$STOW_DIR" -t "$HOME" "$DOTFILES_PACKAGE" 2>&1 | grep -q "would cause conflicts"; then
        print_success "No conflicts detected"
    else
        print_warning "Conflicts detected, attempting to resolve"
        # Remove conflicting files/symlinks
        stow -n -d "$STOW_DIR" -t "$HOME" "$DOTFILES_PACKAGE" 2>&1 | grep "existing target" | \
            sed 's/.*existing target //' | sed 's/ since.*//' | \
            while read -r conflict; do
                local target="$HOME/$conflict"
                if [ -e "$target" ] && [ ! -d "$target" ]; then
                    print_warning "Removing conflict: $conflict"
                    rm -f "$target"
                fi
            done
    fi

    # Stow the dotfiles
    print_substep "Deploying dotfiles with stow"
    if stow -d "$STOW_DIR" -t "$HOME" "$DOTFILES_PACKAGE"; then
        print_success "Dotfiles deployed from $DOTFILES_SRC to $HOME"
    else
        print_error "Failed to stow dotfiles"
        exit 1
    fi

    # Check for local changes in the source repository after deployment.
    print_substep "Checking for local changes"
    if ! git -C "$PROJECT_ROOT" diff-index --quiet HEAD -- 2>/dev/null; then
        print_warning "Local repository changes detected"
        print_info "Review changes with: git -C $PROJECT_ROOT status"
    else
        print_success "No local changes"
    fi

    echo
    print_success "Dotfiles installation completed!"
}

# Uninstall function
uninstall_dotfiles() {
    print_step "Uninstalling dotfiles"

    # Check stow is installed
    if ! command -v stow &> /dev/null; then
        print_error "stow is not installed"
        exit 1
    fi

    # Unstow dotfiles
    print_substep "Removing stow links from $HOME"

    cleanup_stale_home_git_link
    cleanup_legacy_dotfiles_links

    if stow -D -d "$STOW_DIR" -t "$HOME" "$DOTFILES_PACKAGE" 2>/dev/null; then
        print_success "Dotfiles unstowed"
    else
        print_warning "Some links may not have been removed"
    fi

    echo
    print_success "Dotfiles uninstalled!"
    if [ -d "$LEGACY_DOTFILES_TARGET" ]; then
        print_info "Legacy dotfiles directory still exists at: $LEGACY_DOTFILES_TARGET"
        print_info "Remove it manually if you no longer need it"
    fi
}

# Show usage
usage() {
    echo "Usage: $0 <install|uninstall>"
    echo
    echo "Commands:"
    echo "  install     Install dotfiles using stow"
    echo "              - Uses the repository's dotfiles/ directory as the stow package"
    echo "              - Creates symlinks in \$HOME directly from the repo"
    echo "              - Cleans up legacy ~/.dotfiles deployments when found"
    echo
    echo "  uninstall   Uninstall dotfiles"
    echo "              - Removes stow symlinks created from the repository"
    echo "              - Also cleans up legacy ~/.dotfiles links when possible"
    echo
    echo "Required tools: stow, git"
    echo
    echo "Example:"
    echo "  $0 install"
    echo "  $0 uninstall"
}

# Main
main() {
    if [ $# -eq 0 ]; then
        print_error "No command specified"
        echo
        usage
        exit 1
    fi

    local command="$1"

    case "$command" in
        install)
            install_dotfiles
            ;;
        uninstall)
            uninstall_dotfiles
            ;;
        -h|--help|help)
            usage
            ;;
        *)
            print_error "Unknown command: $command"
            echo
            usage
            exit 1
            ;;
    esac
}

main "$@"
