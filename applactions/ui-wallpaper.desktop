[Desktop Entry]
Version=1.0
Type=Application
Name=Wallpaper Switcher
Name[zh_CN]=壁纸设置
Comment=Change wallpaper from local files, Bing, or pixel art
Comment[zh_CN]=壁纸设置（本地 / 必应 / 像素风）
Exec=sh -c "$HOME/.local/bin/ui-wallpaper"
Icon=$HOME/.local/share/applications/icons/ui-wallpaper.png
Terminal=false
Categories=Settings;DesktopSettings;
Keywords=wallpaper;background;bing;pixel;pixelart;
Keywords[zh_CN]=壁纸;背景;必应;像素;像素风;bz;
