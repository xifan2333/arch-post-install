# River session environment
# This file is sourced by uwsm before starting River

# User binaries path
export PATH="$HOME/.local/bin:$PATH"

# Default applications
# TERMINAL is the single source of truth for which terminal River/scripts launch.
# Change it here, then relogin (or restart River session). Do not hardcode
# kitty/wezterm elsewhere — read $TERMINAL instead.
export TERMINAL="${TERMINAL:-wezterm}"
export EDITOR="${EDITOR:-nvim}"
export VISUAL="${VISUAL:-nvim}"
export BROWSER="${BROWSER:-qutebrowser}"
export FILE_MANAGER="${FILE_MANAGER:-pcmanfm}"
export FILE_MANAGER_TUI="${FILE_MANAGER_TUI:-yazi}"
export CODE_EDITOR="${CODE_EDITOR:-code}"

# Keyboard
export KB_LAYOUT="${KB_LAYOUT:-us}"
export KB_OPTIONS="${KB_OPTIONS:-caps:swapescape}"

# sudo askpass helper for Wayland
export SUDO_ASKPASS=/usr/lib/lxqt-openssh-askpass/lxqt-openssh-askpass
