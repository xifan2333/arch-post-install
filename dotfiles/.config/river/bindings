#!/bin/sh
# River 快捷键

mod="Mod4"  # Super/Windows 键

# 快捷键提示生成规则：
# 顶层且不带 ":" 的注释会被识别为分组
# 行尾注释或某条绑定正上方最近的注释会被识别为描述
# 可选覆盖指令：@shortcut-desc ...、@shortcut-hide、@shortcut-section ...

# 应用启动
riverctl map normal $mod Return spawn "uwsm app -- $TERMINAL"                                # 终端
riverctl map normal $mod Space spawn "uwsm app -- ui-wofi"                                  # 应用启动器
riverctl map normal $mod slash spawn "uwsm app -- ui-shortcuts"                             # 快捷键提示
riverctl map normal $mod V spawn "uwsm app -- ui-clipboard"                                 # 剪贴板历史
riverctl map normal $mod B spawn "uwsm app -- qutebrowser"                                 # 浏览器
riverctl map normal $mod E spawn "uwsm app -- pcmanfm"                                      # 文件管理器（GUI）
riverctl map normal $mod+Shift E spawn "uwsm app -- $TERMINAL -e lf"                        # 文件管理器（TUI）
riverctl map normal $mod C spawn "uwsm app -- code"                                         # VSCode
riverctl map normal $mod G spawn "uwsm app -- screenrecord-toggle-full"                      # 录屏开关

# 窗口管理
riverctl map normal $mod W close                                    # 关闭窗口
riverctl map normal $mod F toggle-fullscreen                        # 切换全屏
riverctl map normal None F11 toggle-fullscreen                      # 切换全屏（F11）
riverctl map normal $mod+Shift Q exit                               # 退出 River
riverctl map normal $mod+Shift R spawn river-reload                 # 重载 River 配置

# 焦点切换 HJKL
riverctl map normal $mod H focus-view left                          # 焦点到左侧
riverctl map normal $mod J focus-view next                          # 焦点到下一个窗口
riverctl map normal $mod K focus-view previous                      # 焦点到上一个窗口
riverctl map normal $mod L focus-view right                         # 焦点到右侧

# 焦点切换 方向键
riverctl map normal $mod Up focus-view previous                     # 焦点到上一个窗口
riverctl map normal $mod Down focus-view next                       # 焦点到下一个窗口

# 窗口交换 HJKL
riverctl map normal ${mod}+Shift H swap left                        # 与左侧交换
riverctl map normal ${mod}+Shift J swap next                        # 与下一个交换
riverctl map normal ${mod}+Shift K swap previous                    # 与上一个交换
riverctl map normal ${mod}+Shift L swap right                       # 与右侧交换

# 窗口交换 方向键
riverctl map normal ${mod}+Shift Up swap previous                   # 与上一个交换
riverctl map normal ${mod}+Shift Down swap next                     # 与下一个交换

# 布局方向
riverctl map normal ${mod}+Shift Left send-layout-cmd rivertile "main-location left"   # 横向布局
riverctl map normal ${mod}+Shift Right send-layout-cmd rivertile "main-location top"   # 纵向布局

# 布局控制 YUIO
riverctl map normal $mod Y send-layout-cmd rivertile "main-location left"        # 横向布局（主区域在左）
riverctl map normal $mod U send-layout-cmd rivertile "main-location top"         # 纵向布局（主区域在上）
riverctl map normal $mod I send-layout-cmd rivertile "main-ratio -0.05"          # 减小主区域比例
riverctl map normal $mod O send-layout-cmd rivertile "main-ratio +0.05"          # 增大主区域比例

# 布局控制 方向键
riverctl map normal $mod Left send-layout-cmd rivertile "main-ratio -0.05"       # 减小主区域比例
riverctl map normal $mod Right send-layout-cmd rivertile "main-ratio +0.05"      # 增大主区域比例

# 窗口状态
riverctl map normal $mod P toggle-float                             # 切换浮动
riverctl map normal $mod+Shift Return zoom                          # 放大到主区域

# 多显示器
riverctl map normal $mod Period focus-output next                   # 焦点到下一个显示器
riverctl map normal $mod Comma focus-output previous                # 焦点到上一个显示器
riverctl map normal ${mod}+Shift Period send-to-output next         # 发送到下一个显示器
riverctl map normal ${mod}+Shift Comma send-to-output previous      # 发送到上一个显示器

# 截图
riverctl map normal $mod Print spawn "uwsm app -- screenshot-edit-area"                    # 区域截图并标注
riverctl map normal ${mod}+Shift Print spawn "uwsm app -- screenshot-colorpicker"           # 取色器
riverctl map normal None Print spawn "uwsm app -- screenshot-save-area"                    # 区域截图
riverctl map normal Shift Print spawn "uwsm app -- screenshot-save-full"                   # 全屏截图
riverctl map normal Control Print spawn "uwsm app -- screenshot-preview-area"              # 区域截图并预览
riverctl map normal Mod1 Print spawn "uwsm app -- screenshot-temp-area"                    # 区域截图到临时路径

# 录屏
riverctl map normal ${mod}+Mod1 G spawn "uwsm app -- screenrecord-start-area"              # 区域录屏

# 媒体键 音量
riverctl map -repeat normal None XF86AudioRaiseVolume spawn "pamixer -i 5"
riverctl map -repeat normal None XF86AudioLowerVolume spawn "pamixer -d 5"
riverctl map normal None XF86AudioMute spawn "pamixer -t"
riverctl map normal None XF86AudioMicMute spawn "pactl set-source-mute @DEFAULT_SOURCE@ toggle"

# 媒体键 亮度
riverctl map -repeat normal None XF86MonBrightnessUp spawn "brightnessctl set +5%"
riverctl map -repeat normal None XF86MonBrightnessDown spawn "brightnessctl set 5%-"

# 媒体键 播放控制
riverctl map normal None XF86AudioPlay spawn "playerctl play-pause"
riverctl map normal None XF86AudioNext spawn "playerctl next"
riverctl map normal None XF86AudioPrev spawn "playerctl previous"

# 锁屏
riverctl map normal $mod Escape spawn "uwsm app -- screen-lock"                   # 锁屏（Super + ESC）
riverctl map normal $mod+Shift W spawn "uwsm app -- screen-lock"                  # 锁屏

# 输入法
riverctl map normal Control Space spawn "fcitx5-remote -t"          # 切换输入法

# 工作区管理
# 切换到 1 到 9 号工作区
for i in $(seq 1 9); do
    # Super+[1-9]：聚焦到对应工作区
    riverctl map normal $mod $i spawn "uwsm app -- river-workspace-focus $i"

    # Super+Shift+[1-9]：发送当前窗口到对应工作区
    riverctl map normal ${mod}+Shift $i spawn "uwsm app -- river-workspace-send $i"

    # Super+Ctrl+[1-9]：切换对应工作区可见性
    riverctl map normal ${mod}+Control $i spawn "uwsm app -- river-workspace-toggle $i"

    # Super+Alt+[1-9]：给当前窗口追加对应工作区标签
    riverctl map normal ${mod}+Mod1 $i spawn "uwsm app -- river-workspace-tag $i"
done

# Super+=：查看全部普通工作区（1 到 9，不含 scratchpad）
# 说明：这里用 equal，是因为输入加号需要按 Shift
riverctl map normal $mod equal spawn "uwsm app -- river-workspace-view-all"

# Super+-：窗口常驻全部普通工作区
riverctl map normal $mod minus spawn "uwsm app -- river-sticky"

# Scratchpad
# Super+0：切换 scratchpad 可见性
riverctl map normal $mod 0 spawn "uwsm app -- river-scratchpad-toggle"

# Alt+Space：切换 scratchpad 可见性（备用）
riverctl map normal Mod1 Space spawn "uwsm app -- river-scratchpad-toggle"

# Super+Shift+0：发送当前窗口到 scratchpad
riverctl map normal ${mod}+Shift 0 spawn "uwsm app -- river-scratchpad-send"

# 鼠标绑定
riverctl map-pointer normal $mod BTN_LEFT move-view                 # 用鼠标移动窗口
riverctl map-pointer normal $mod BTN_RIGHT resize-view              # 用鼠标调整窗口大小
riverctl map-pointer normal $mod BTN_MIDDLE toggle-float            # 中键切换浮动
