#!/bin/bash
# Sync WezTerm font with current system font

set -e

FONT_NAME="$1"

if [ -z "$FONT_NAME" ]; then
    echo "Error: Font name not provided" >&2
    exit 1
fi

WEZTERM_DIR="$HOME/.config/wezterm"
WEZTERM_CONFIG="$WEZTERM_DIR/wezterm.lua"
WEZTERM_FONT_CONFIG="$WEZTERM_DIR/font.lua"

# Check if WezTerm config exists
if [ ! -f "$WEZTERM_CONFIG" ]; then
    # WezTerm not configured, exit silently
    exit 0
fi

mkdir -p "$WEZTERM_DIR"

# Update font family in dedicated overlay file (hot-reloaded by wezterm.lua)
cat > "$WEZTERM_FONT_CONFIG" <<FONT
-- Auto-generated by font-sync-wezterm
return {
  font_family = "$FONT_NAME",
  font_size = 10.5,
}
FONT

# Touch main config so running WezTerm instances reload
touch "$WEZTERM_CONFIG"

echo "WezTerm font updated to: $FONT_NAME"
