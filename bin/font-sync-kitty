#!/bin/bash
# Sync Kitty font with current system font

set -e

FONT_NAME="$1"

if [ -z "$FONT_NAME" ]; then
    echo "Error: Font name not provided" >&2
    exit 1
fi

KITTY_CONFIG="$HOME/.config/kitty/kitty.conf"
KITTY_FONT_CONFIG="$HOME/.config/kitty/font.conf"

# Check if Kitty config exists
if [ ! -f "$KITTY_CONFIG" ]; then
    # Kitty not configured, exit silently
    exit 0
fi

# Update font family in dedicated overlay file
cat > "$KITTY_FONT_CONFIG" <<EOF
font_family $FONT_NAME
bold_font $FONT_NAME
italic_font $FONT_NAME
bold_italic_font $FONT_NAME
font_size 10.5
EOF

# Reload running Kitty instances
if pgrep -x kitty >/dev/null; then
    killall -SIGUSR1 kitty 2>/dev/null || true
fi

echo "Kitty font updated to: $FONT_NAME"
