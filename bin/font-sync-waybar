#!/bin/bash
# Sync Waybar font with current system font

set -e

FONT_NAME="$1"

if [ -z "$FONT_NAME" ]; then
    echo "Error: Font name not provided" >&2
    exit 1
fi

WAYBAR_STYLE="$HOME/.config/waybar/style.css"
WAYBAR_FONT_STYLE="$HOME/.config/waybar/font.css"

# Check if Waybar config exists
if [ ! -f "$WAYBAR_STYLE" ]; then
    # Waybar not configured, exit silently
    exit 0
fi

# Update font family in dedicated overlay file
cat > "$WAYBAR_FONT_STYLE" <<EOF
* {
    font-family: "$FONT_NAME", "Symbols Nerd Font", sans-serif;
}
EOF

# Restart Waybar if running
if pgrep -x waybar >/dev/null; then
    killall waybar
    riverctl spawn waybar &
fi

echo "Waybar font updated to: $FONT_NAME"
