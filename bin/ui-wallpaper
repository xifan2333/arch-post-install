#!/bin/bash
# Wallpaper switcher with local and network (Bing / pixel art) modes
# Usage: ui-wallpaper

set -e

# Load i18n
source i18n-core

# Wallpaper state file - stores current wallpaper path
WALLPAPER_STATE="${XDG_CONFIG_HOME:-$HOME/.config}/current/wallpaper"

# Wallpaper directory - user's Pictures folder
XDG_PICTURES_DIR="${XDG_PICTURES_DIR:-$(xdg-user-dir PICTURES)}"
WALLPAPER_DIR="$XDG_PICTURES_DIR/wallpapers"

# Ensure wallpaper directory exists
mkdir -p "$WALLPAPER_DIR"

# Notification helper
notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "${i18n[wallpaper_title]}" "$1"
    fi
}

# Set wallpaper using swaybg (Wayland)
set_wallpaper() {
    local wallpaper="$1"

    # Kill existing swaybg
    pkill swaybg 2>/dev/null || true

    # Start new swaybg in background
    swaybg -i "$wallpaper" -m fill &

    # Save wallpaper path to state file
    mkdir -p "$(dirname "$WALLPAPER_STATE")"
    echo "$wallpaper" > "$WALLPAPER_STATE"

}

# Download Bing daily wallpaper
download_bing_wallpaper() {

    # Random idx (0-7)
    RANDOM_IDX=$((RANDOM % 8))

    # Bing wallpaper API (official) - fetch 8 days starting from random idx
    BING_API="https://www.bing.com/HPImageArchive.aspx?format=js&idx=${RANDOM_IDX}&n=8&mkt=zh-CN"

    # Use fixed filename to avoid file redundancy (overwrite on each download)
    FILENAME="bing.jpg"
    WALLPAPER_PATH="$WALLPAPER_DIR/$FILENAME"

    # Random index for selecting from 8 wallpapers (0-7)
    RANDOM_SELECT=$((RANDOM % 8))

    # Fetch JSON and extract random image URL using jq
    IMAGE_URL=$(curl -s "$BING_API" | jq -r ".images[${RANDOM_SELECT}].url")

    if [ -z "$IMAGE_URL" ] || [ "$IMAGE_URL" = "null" ]; then
        notify "${i18n[wallpaper_bing_failed]}"
        echo "${i18n[wallpaper_bing_error]}" >&2
        exit 1
    fi

    # Construct full URL (API returns relative path)
    FULL_URL="https://www.bing.com${IMAGE_URL}"

    # Download wallpaper (overwrite if exists)
    if ! curl -L -s -o "$WALLPAPER_PATH" "$FULL_URL"; then
        notify "${i18n[wallpaper_bing_failed]}"
        echo "${i18n[wallpaper_bing_error]}" >&2
        exit 1
    fi

    # Set as wallpaper
    set_wallpaper "$WALLPAPER_PATH"
    notify "${i18n[wallpaper_bing_success]}"
}

# Download random pixel art wallpaper from Wallhaven
download_pixel_wallpaper() {
    # Wallhaven public search API — random SFW pixel art at 1080p+
    WALLHAVEN_API="https://wallhaven.cc/api/v1/search?q=pixel+art&atleast=1920x1080&sorting=random&purity=100"

    RESPONSE=$(curl -s "$WALLHAVEN_API")
    IMAGE_URL=$(echo "$RESPONSE" | jq -r '.data[0].path // empty')
    FILE_TYPE=$(echo "$RESPONSE" | jq -r '.data[0].file_type // empty')

    if [ -z "$IMAGE_URL" ] || [ "$IMAGE_URL" = "null" ]; then
        notify "${i18n[wallpaper_pixel_failed]}"
        echo "${i18n[wallpaper_pixel_error]}" >&2
        exit 1
    fi

    case "$FILE_TYPE" in
        image/png) EXT="png" ;;
        image/webp) EXT="webp" ;;
        *) EXT="jpg" ;;
    esac

    # Fixed basename; drop stale extensions from previous downloads
    rm -f "$WALLPAPER_DIR"/pixel.jpg "$WALLPAPER_DIR"/pixel.jpeg \
        "$WALLPAPER_DIR"/pixel.png "$WALLPAPER_DIR"/pixel.webp
    FILENAME="pixel.${EXT}"
    WALLPAPER_PATH="$WALLPAPER_DIR/$FILENAME"

    if ! curl -L -s -o "$WALLPAPER_PATH" "$IMAGE_URL"; then
        notify "${i18n[wallpaper_pixel_failed]}"
        echo "${i18n[wallpaper_pixel_error]}" >&2
        exit 1
    fi

    # Reject empty / failed downloads
    if [ ! -s "$WALLPAPER_PATH" ]; then
        rm -f "$WALLPAPER_PATH"
        notify "${i18n[wallpaper_pixel_failed]}"
        echo "${i18n[wallpaper_pixel_error]}" >&2
        exit 1
    fi

    set_wallpaper "$WALLPAPER_PATH"
    notify "${i18n[wallpaper_pixel_success]}"
}

# Select wallpaper from local directory
select_local_wallpaper() {
    # Find all image files in wallpaper directory
    local images=$(find "$WALLPAPER_DIR" -type f \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \) -printf "%f\n" | sort)

    if [ -z "$images" ]; then
        notify "${i18n[wallpaper_none_found]}"
        echo "Error: ${i18n[wallpaper_none_found]}" >&2
        exit 1
    fi

    # Show selection menu
    local selected=$(echo "$images" | ui-wofi --dmenu -p "${i18n[wallpaper_prompt]}")

    # User cancelled
    [ -z "$selected" ] && exit 0

    # Set wallpaper
    WALLPAPER_PATH="$WALLPAPER_DIR/$selected"
    set_wallpaper "$WALLPAPER_PATH"
    notify "$(msg wallpaper_set name "$selected")"
}

# Main menu
MODE=$(printf "%s\n%s\n%s" \
    "${i18n[wallpaper_mode_local]}" \
    "${i18n[wallpaper_mode_bing]}" \
    "${i18n[wallpaper_mode_pixel]}" \
    | ui-wofi --dmenu -p "${i18n[wallpaper_mode_prompt]}")

# User cancelled
[ -z "$MODE" ] && exit 0

case "$MODE" in
    "${i18n[wallpaper_mode_local]}")
        select_local_wallpaper
        ;;
    "${i18n[wallpaper_mode_bing]}")
        download_bing_wallpaper
        ;;
    "${i18n[wallpaper_mode_pixel]}")
        download_pixel_wallpaper
        ;;
    *)
        echo "${i18n[wallpaper_invalid_mode]}" >&2
        exit 1
        ;;
esac
