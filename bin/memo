#!/usr/bin/env python3
import sys
from datetime import datetime

def add_memo():
    if len(sys.argv) < 2:
        print("用法: memo 想法内容 #标签")
        sys.exit(1)
    
    args = sys.argv[1:]
    content_parts = []
    hashtags = []
    
    for arg in args:
        if arg.startswith('#'):
            hashtags.append(arg)
        else:
            content_parts.append(arg)
    
    content = ' '.join(content_parts)
    hashtag = ' '.join(hashtags)
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    memo_file = "/home/xifan/documents/notes/000-M-Memo-积流.md"
    memo_line = f"- {content} {hashtag} {timestamp}\n"
    
    with open(memo_file, "a", encoding="utf-8") as f:
        f.write(memo_line)
    
    print(f"已添加: {memo_line.strip()}")

if __name__ == "__main__":
    add_memo()
