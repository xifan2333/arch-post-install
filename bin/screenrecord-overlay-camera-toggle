#!/bin/bash
# Toggle camera overlay on/off
set -e
source i18n-core

PID=$(pgrep -f "python3.*screenrecord-overlay-camera" | head -1)

if [ -n "$PID" ]; then
    kill "$PID" 2>/dev/null
    echo "$(msg screenrecord_overlay_camera_off)"
else
    nohup screenrecord-overlay-camera &>/dev/null &
    echo "$(msg screenrecord_overlay_camera_on)"
fi
