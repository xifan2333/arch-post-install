#!/bin/bash
# Toggle captions overlay on/off
set -e
source i18n-core

PID=$(pgrep -f "[p]ython3.*screenrecord-overlay-captions" | head -1)

if [ -n "$PID" ]; then
    kill "$PID" 2>/dev/null
    echo "$(msg screenrecord_overlay_captions_off)"
else
    nohup screenrecord-overlay-captions &>/dev/null &
    echo "$(msg screenrecord_overlay_captions_on)"
fi
