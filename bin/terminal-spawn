#!/bin/bash
# Launch the configured $TERMINAL with portable flags.
# Usage:
#   terminal-spawn                 # new interactive window
#   terminal-spawn -e CMD [ARGS]   # run command (kitty-style -e)
#   terminal-spawn -- CMD [ARGS]   # same as -e
#
# Resolution order for which terminal to start:
#   1. Default declared in ~/.config/uwsm/env  (${TERMINAL:-wezterm})
#   2. Current $TERMINAL environment variable
#   3. wezterm, then kitty
#
# Why prefer uwsm/env over the live $TERMINAL? River's process env can stay
# stuck on an old value (e.g. kitty) for the whole session; Super+Return must
# still honor the config file after you switch defaults.

set -e

uwsm_terminal_default() {
    local envf="$HOME/.config/uwsm/env"
    local line value
    [[ -f "$envf" ]] || return 1

    while IFS= read -r line || [[ -n "$line" ]]; do
        case "$line" in
            export\ TERMINAL=*|TERMINAL=*)
                value="${line#*TERMINAL=}"
                value="${value#\"}"
                value="${value%\"}"
                value="${value#\'}"
                value="${value%\'}"
                # ${TERMINAL:-wezterm}  →  wezterm
                if [[ "$value" == *'${TERMINAL:-'*'}'* ]]; then
                    value="${value#*\$\{TERMINAL:-}"
                    value="${value%%\}*}"
                fi
                if [[ -n "$value" ]]; then
                    printf '%s\n' "$value"
                    return 0
                fi
                ;;
        esac
    done <"$envf"
    return 1
}

pick_terminal() {
    local candidate
    for candidate in "$(uwsm_terminal_default 2>/dev/null || true)" "${TERMINAL:-}" "wezterm" "kitty"; do
        [[ -n "$candidate" ]] || continue
        if command -v "$candidate" >/dev/null 2>&1; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    echo "terminal-spawn: no terminal found" >&2
    return 1
}

TERMINAL_BIN="$(pick_terminal)"
TERMINAL_NAME="$(basename "$TERMINAL_BIN")"

run_cmd=()
if [[ "${1:-}" == "-e" || "${1:-}" == "--" ]]; then
    shift
    run_cmd=("$@")
fi

case "$TERMINAL_NAME" in
    wezterm)
        # Always start a real GUI process so Super+Return behaves like kitty
        # (new window), not "attach to existing mux and maybe open a tab".
        if [[ ${#run_cmd[@]} -eq 0 ]]; then
            exec uwsm app -- wezterm start --always-new-process
        else
            exec uwsm app -- wezterm start --always-new-process -- "${run_cmd[@]}"
        fi
        ;;
    *)
        if [[ ${#run_cmd[@]} -eq 0 ]]; then
            exec uwsm app -- "$TERMINAL_BIN"
        else
            exec uwsm app -- "$TERMINAL_BIN" -e "${run_cmd[@]}"
        fi
        ;;
esac
