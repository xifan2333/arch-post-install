#!/bin/bash
# Launch a floating terminal with a command

# Parse options
TERMINAL_CLASS="floating-terminal"
TERMINAL_TITLE="Terminal"
SHOW_LOGO=false
SHOW_DONE=false
CLOSE_ON_EXIT=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --class=*)
            TERMINAL_CLASS="${1#*=}"
            shift
            ;;
        --title=*)
            TERMINAL_TITLE="${1#*=}"
            shift
            ;;
        --logo)
            SHOW_LOGO=true
            shift
            ;;
        --done)
            SHOW_DONE=true
            shift
            ;;
        --close)
            CLOSE_ON_EXIT=true
            shift
            ;;
        --)
            shift
            break
            ;;
        *)
            break
            ;;
    esac
done

cmd="$*"

# Build the command chain
cmd_chain=""

if [ "$SHOW_LOGO" = true ]; then
    cmd_chain="component-show-logo"
fi

if [ -n "$cmd" ]; then
    if [ -n "$cmd_chain" ]; then
        cmd_chain="$cmd_chain; $cmd"
    else
        cmd_chain="$cmd"
    fi
fi

if [ "$SHOW_DONE" = true ]; then
    if [ -n "$cmd_chain" ]; then
        cmd_chain="$cmd_chain; component-show-done"
    else
        cmd_chain="component-show-done"
    fi
fi

# Launch flags differ by terminal; which binary is only $TERMINAL (uwsm/env).
TERMINAL="${TERMINAL:-wezterm}"
TERMINAL_NAME="$(basename "$TERMINAL")"
launch_terminal() {
    local prog_args=("$@")

    case "$TERMINAL_NAME" in
        wezterm)
            if [ ${#prog_args[@]} -eq 0 ]; then
                setsid -f uwsm app -- wezterm start --always-new-process --class="$TERMINAL_CLASS"
            else
                setsid -f uwsm app -- wezterm start --always-new-process --class="$TERMINAL_CLASS" -- "${prog_args[@]}"
            fi
            ;;
        *)
            if [ ${#prog_args[@]} -eq 0 ]; then
                setsid -f uwsm app -- "$TERMINAL" --class="$TERMINAL_CLASS" --title="$TERMINAL_TITLE"
            else
                setsid -f uwsm app -- "$TERMINAL" --class="$TERMINAL_CLASS" --title="$TERMINAL_TITLE" "${prog_args[@]}"
            fi
            ;;
    esac
}

# Launch terminal
if [ -z "$cmd_chain" ]; then
    launch_terminal
else
    if [ "$SHOW_DONE" = true ] || [ "$CLOSE_ON_EXIT" = true ]; then
        launch_terminal "$SHELL" -l -c "$cmd_chain"
    else
        launch_terminal "$SHELL" -l -c "$cmd_chain; exec $SHELL -l"
    fi
fi
